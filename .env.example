# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Google Gemini (LLM + vision + voice transcription) ────────────────────────
# Get your free API key at https://aistudio.google.com/app/apikey
# Free tier: 1500 requests/day, 1M token context window.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model (default is gemini-2.0-flash, free tier).
# GEMINI_MODEL=gemini-1.5-pro

# ── Google Service Account (Drive + Sheets + Docs) ────────────────────────────
# Path to your downloaded service account JSON key file (do NOT commit this).
# Share the Lab Assistant Drive folder and Sheets file with the service account email.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ── Google Drive ──────────────────────────────────────────────────────────────
# Folder IDs taken from the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_PROTOCOLS_FOLDER_ID=your_protocols_folder_id_here
DRIVE_SESSION_REPORTS_FOLDER_ID=your_session_reports_folder_id_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Spreadsheet ID from the Sheets URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (Whisper transcription only) ───────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Service Account ────────────────────────────────────────────────────
# Path to your downloaded service account JSON key file (do NOT commit this file).
# Share the Lab Assistant Drive folder and Sheets file with the service account email.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ── Google Drive ──────────────────────────────────────────────────────────────
# Folder IDs taken from the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_PROTOCOLS_FOLDER_ID=your_protocols_folder_id_here
DRIVE_SESSION_REPORTS_FOLDER_ID=your_session_reports_folder_id_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Spreadsheet ID taken from the Sheets URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
